{
  "name": "town-zero",
  "private": true,
  "workspaces": ["shared", "server", "client"],
  "engines": {
    "node": ">= 22"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "scripts": {
    "build": "pnpm --filter @town-zero/shared build && pnpm --filter @town-zero/server build",
    "dev:server": "pnpm --filter @town-zero/shared build && pnpm --filter @town-zero/server dev",
    "dev:client": "pnpm --filter @town-zero/client dev",
    "test": "pnpm --filter @town-zero/server test && pnpm --filter @town-zero/client test",
    "typecheck:types": "pnpm --filter @town-zero/shared typecheck:types"
  }
}
